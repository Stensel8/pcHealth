<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="pcHealth.Pages.ProgramsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:pcHealth">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="28,20,28,4" Spacing="2">
            <TextBlock Text="Programs"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Install common diagnostic and utility software via winget."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Programs list -->
        <ListView x:ConnectionId='2'
            Grid.Row="1"
            x:Name="ProgramsList"
                                           
            SelectionMode="None"
            Padding="24,8,24,24">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,4,0,0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate                               >
                    <Border x:ConnectionId='4' Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8"
                            Padding="20,14">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <FontIcon x:ConnectionId='5'                        FontSize="24"
                                      VerticalAlignment="Center"/>

                            <!-- Name + note -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock x:ConnectionId='7'                     
                                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock x:ConnectionId='8'                     
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                               />
                            </StackPanel>

                            <!-- Action button -->
                            <Button x:ConnectionId='6' Grid.Column="2"
                                                                  
                                    Style="{StaticResource AccentButtonStyle}"
                                                  
                                                            
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>

