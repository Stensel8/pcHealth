<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="pcHealth.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="pcHealth">

    <NavigationView x:ConnectionId='2'
        x:Name="NavView"
        IsBackButtonVisible="Auto"
        PaneDisplayMode="Left"
        OpenPaneLength="200"
                                                   
                                             
                               >

        <NavigationView.PaneHeader>
            <TextBlock Text="pcHealth"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="16,12,0,4"/>
        </NavigationView.PaneHeader>

        <NavigationView.MenuItems>
            <NavigationViewItem Tag="tools" Content="Tools">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE90F;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="programs" Content="Programs">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE896;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Frame x:ConnectionId='3' x:Name="ContentFrame"/>

    </NavigationView>
</Window>

