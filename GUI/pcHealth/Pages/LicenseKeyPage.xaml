<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="pcHealth.Pages.LicenseKeyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header          -->
            <RowDefinition Height="*"/>      <!-- Extraction cards -->
            <RowDefinition Height="Auto"/>   <!-- Button row      -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="28,20,28,8" Spacing="4">
            <TextBlock Text="Windows License Key"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock x:Name="OsInfoText"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Extraction cards -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="28,8,28,8" Spacing="12">

                <!-- Method 1: OA3 key from UEFI/BIOS firmware -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,14">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Method 1 - UEFI/BIOS Firmware (OA3)"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Name="Oa3StatusText"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="Oa3KeyText"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="14" IsTextSelectionEnabled="True"/>
                        </StackPanel>
                        <FontIcon Grid.Column="1" x:Name="Oa3Icon"
                                  FontSize="20" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Method 2: key decoded from the registry DigitalProductId blob -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,14">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Method 2 - Registry (DigitalProductId)"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Name="RegStatusText"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="RegKeyText"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="14" IsTextSelectionEnabled="True"/>
                        </StackPanel>
                        <FontIcon Grid.Column="1" x:Name="RegIcon"
                                  FontSize="20" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Best key summary, shown in a larger font for easy reading -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Primary Key"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock x:Name="PrimaryKeyText"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   FontSize="20" FontWeight="SemiBold"
                                   IsTextSelectionEnabled="True"/>
                        <TextBlock x:Name="KeySourceText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <!-- Shown only when a KMS/generic placeholder key is detected -->
                        <InfoBar x:Name="GenericWarning"
                                 IsOpen="False"
                                 Severity="Warning"
                                 Title="Generic placeholder key detected"
                                 Message="This key will not activate Windows. Your system may use a digital licence linked to your Microsoft account, or was activated via KMS/MAK."/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Button row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Padding="28,12,28,20" Spacing="8">
            <Button x:Name="CopyBtn"
                    Content="Copy Key"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="False"
                    Click="CopyBtn_Click"/>
            <Button x:Name="SaveBtn"
                    Content="Save Report"
                    IsEnabled="False"
                    Click="SaveBtn_Click"/>
            <Button Content="Back"
                    Click="BackBtn_Click"/>
        </StackPanel>

    </Grid>
</Page>
