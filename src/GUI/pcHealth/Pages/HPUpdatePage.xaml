<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="pcHealth.Pages.HPUpdatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="28,20,28,8" Spacing="4">
            <TextBlock Text="Update HP Drivers"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Installs HP Image Assistant to detect and update HP-specific drivers."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <InfoBar Grid.Row="1" Margin="28,0,28,8"
                 IsOpen="True" Severity="Informational" IsClosable="False"
                 Title="HP devices only"
                 Message="HP Image Assistant is only useful on HP laptops and desktops."/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Padding="28,8,28,12" Spacing="10">
            <Button Content="Install HP Image Assistant"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.InstallCommand}"/>
            <ProgressRing IsActive="{x:Bind ViewModel.IsRunning, Mode=OneWay}" Width="22" Height="22" VerticalAlignment="Center"/>
            <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                       VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Margin="28,0,28,8">
            <ScrollViewer x:Name="OutputScroller" VerticalScrollBarVisibility="Auto" Padding="16">
                <TextBlock Text="{x:Bind ViewModel.Output, Mode=OneWay}"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="12" IsTextSelectionEnabled="True" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Padding="28,4,28,20" Spacing="8">
            <Button Content="Back" Click="BackBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
