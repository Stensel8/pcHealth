<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="pcHealth.Pages.SystemInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Padding="28,20,28,8" Spacing="4">
            <TextBlock Text="System Information"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Operating system, firmware, security, and hardware overview."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ContentPanel" Padding="28,8,28,8" Spacing="12">

                <StackPanel x:Name="LoadingPanel" Orientation="Horizontal" Spacing="12">
                    <ProgressRing IsActive="True" Width="24" Height="24" VerticalAlignment="Center"/>
                    <TextBlock Text="Loading system information…" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <InfoBar x:Name="ErrorBar" IsOpen="False" Severity="Error"
                         Title="Could not load system information"/>

                <!-- OS card -->
                <Border x:Name="OsCard" Visibility="Collapsed"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE770;" FontSize="16" VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Operating System"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <StackPanel x:Name="OsRows" Spacing="5"/>
                    </StackPanel>
                </Border>

                <!-- Machine card -->
                <Border x:Name="MachineCard" Visibility="Collapsed"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7F4;" FontSize="16" VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Machine"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <StackPanel x:Name="MachineRows" Spacing="5"/>
                    </StackPanel>
                </Border>

                <!-- Firmware & Security card -->
                <Border x:Name="FirmwareCard" Visibility="Collapsed"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8D7;" FontSize="16" VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Firmware &amp; Security"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <StackPanel x:Name="FirmwareRows" Spacing="5"/>
                    </StackPanel>
                </Border>

                <!-- Hardware Summary card -->
                <Border x:Name="HardwareCard" Visibility="Collapsed"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE950;" FontSize="16" VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Hardware Summary"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <StackPanel x:Name="HardwareRows" Spacing="5"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Button row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Padding="28,12,28,20" Spacing="8">
            <Button x:Name="CopyBtn" Content="Copy" IsEnabled="False" Click="CopyBtn_Click"/>
            <Button Content="Back" Click="BackBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
