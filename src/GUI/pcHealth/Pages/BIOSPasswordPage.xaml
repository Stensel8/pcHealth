<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="pcHealth.Pages.BIOSPasswordPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="28,20,28,8" Spacing="4">
            <TextBlock Text="BIOS Password Recovery"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Tools for recovering locked BIOS passwords."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="28,8,28,8" Spacing="12">

                <!-- bios-pw.org -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="bios-pw.org" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock TextWrapping="Wrap"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Enter the hash or error code shown on your locked BIOS screen to generate a recovery code."/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Open" VerticalAlignment="Center"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.OpenBiosPwCommand}"/>
                    </Grid>
                </Border>

                <!-- GitHub repo -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="pwgen-for-bios (GitHub)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock TextWrapping="Wrap"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Source code and documentation by @bacher09. Learn how the BIOS password generation algorithm works."/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Open" VerticalAlignment="Center"
                                Command="{x:Bind ViewModel.OpenRepoCommand}"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Padding="28,12,28,20" Spacing="8">
            <Button Content="Back" Click="BackBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
