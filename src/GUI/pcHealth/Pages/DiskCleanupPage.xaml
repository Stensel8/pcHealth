<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="pcHealth.Pages.DiskCleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="28,20,28,8" Spacing="4">
            <TextBlock Text="Disk Cleanup"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Remove temporary files, recycle bin contents, and other junk."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="28,8,28,8" Spacing="12">

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20,16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="18" VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Disk Cleanup" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="Opens the Windows Disk Cleanup utility (cleanmgr.exe). Scans for temporary files, thumbnails, system files, and other items that can be safely deleted."/>
                        <Button Content="Open Disk Cleanup"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="OpenBtn_Click"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Padding="28,12,28,20" Spacing="8">
            <Button Content="Back" Click="BackBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
