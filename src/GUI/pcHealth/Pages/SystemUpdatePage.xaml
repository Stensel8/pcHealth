<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="pcHealth.Pages.SystemUpdatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="28,20,28,8" Spacing="4">
            <TextBlock Text="Update All Packages"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Upgrades all installed packages via winget. May take several minutes."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Padding="28,0,28,12" Spacing="10">
            <Button x:Name="RunBtn" Content="Update All Packages"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="RunBtn_Click"/>
            <ProgressRing x:Name="Progress" IsActive="False" Width="22" Height="22" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Margin="28,0,28,8">
            <ScrollViewer x:Name="OutputScroller" VerticalScrollBarVisibility="Auto" Padding="16">
                <TextBlock x:Name="OutputText"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="12" IsTextSelectionEnabled="True"
                           TextWrapping="Wrap"
                           Text="Output will appear here."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Padding="28,4,28,20" Spacing="8">
            <Button Content="Back" Click="BackBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
